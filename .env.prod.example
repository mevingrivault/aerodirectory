# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=aerodirectory
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=aerodirectory

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ─── API ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_min_64_chars_random_string
CORS_ORIGINS=https://navventura.fr

# ─── Email (ex: Brevo, Resend) ───────────────────────────────────────────────
SMTP_HOST=smtp.brevo.com
SMTP_PORT=587
SMTP_FROM=noreply@navventura.fr
SMTP_USER=
SMTP_PASS=

# ─── Stockage fichiers (S3 / Cloudflare R2 / SeaweedFS) ──────────────────────
S3_ENDPOINT=
S3_BUCKET=aerodirectory
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── OpenAIP ─────────────────────────────────────────────────────────────────
OPENAIP_API_KEY=

# ─── Docker ──────────────────────────────────────────────────────────────────
GITHUB_REPO=mevingrivault/aerodirectory
IMAGE_TAG=latest

# ─── Réseau Nginx Proxy Manager ──────────────────────────────────────────────
# Nom du réseau externe de ton NPM (visible dans Portainer > Networks)
PROXY_NETWORK=npm_network
