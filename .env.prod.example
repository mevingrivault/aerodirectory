# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=aerodirectory
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=aerodirectory

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ─── API ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_min_64_chars_random_string
CORS_ORIGINS=https://navventura.fr
APP_URL=https://navventura.fr

# ─── Email (Brevo) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_FROM=noreply@navventura.fr
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Navventura <noreply@navventura.fr>

# ─── Stockage fichiers (SeaweedFS local) ─────────────────────────────────────
# S3_ENDPOINT est hardcodé dans docker-compose.prod.yml → ne pas renseigner ici
# SeaweedFS tourne sans authentification (réseau interne uniquement)
# Ces valeurs sont transmises à l'API mais ignorées par SeaweedFS
S3_BUCKET=navventura
S3_ACCESS_KEY=any_value
S3_SECRET_KEY=any_value
# URL publique pour servir les fichiers (sous-domaine NPM → seaweedfs-filer:8333)
S3_PUBLIC_URL=https://cdn.navventura.fr

# ─── OpenAIP / CheckWX ───────────────────────────────────────────────────────
OPENAIP_API_KEY=
CHECKWX_API_KEY=

# ─── Docker ──────────────────────────────────────────────────────────────────
GITHUB_REPO=mevingrivault/aerodirectory
IMAGE_TAG=latest

# ─── Réseau Nginx Proxy Manager ──────────────────────────────────────────────
# Nom du réseau externe de ton NPM (visible dans Portainer > Networks)
PROXY_NETWORK=npm_network
