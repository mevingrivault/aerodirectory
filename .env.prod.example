POSTGRES_USER=aerodirectory
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=aerodirectory

REDIS_PASSWORD=change_me_redis_password

JWT_SECRET=change_me_min_64_chars_random_string
JWT_REFRESH_SECRET=change_me_another_min_64_chars_random_string
TOTP_ENCRYPTION_KEY=change_me_min_16_chars_random_string
TOTP_WINDOW=2
CORS_ORIGINS=https://navventura.fr
APP_URL=https://navventura.fr

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FROM=noreply@navventura.fr
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Navventura <noreply@navventura.fr>

S3_BUCKET=navventura
S3_ACCESS_KEY=any_value
S3_SECRET_KEY=any_value
S3_PUBLIC_URL=https://cdn.navventura.fr

PHOTO_MAX_UPLOAD_BYTES=5242880
PHOTO_MAX_WIDTH=4096
PHOTO_MAX_HEIGHT=4096
PHOTO_MAX_INPUT_PIXELS=16777216
PHOTO_UPLOAD_TMP_DIR=/tmp/navventura-uploads

CLAMSCAN_ENABLED=true
CLAMSCAN_PATH=/usr/bin/clamscan
CLAMSCAN_DATABASE_PATH=/var/lib/clamav
CLAMSCAN_TIMEOUT_MS=20000
CLAMSCAN_AUTO_UPDATE=false
CLAMAV_FRESHCLAM_CHECKS=12

OPENAIP_API_KEY=
CHECKWX_API_KEY=

SYNC_ENABLED=true
SYNC_TIMEZONE=Europe/Paris
SYNC_OPENAIP_CRON=0 2 * * *
SYNC_OSM_CRON=0 3 * * 0
SYNC_RGPD_CRON=30 4 * * *
SYNC_REGIONS_FULL_CRON=0 5 1 * *
SYNC_REPORT_CRON=30 7 * * *
SYNC_RETRY_ATTEMPTS=3
SYNC_RETRY_BACKOFF_MINUTES=15,30,60
SYNC_REPORT_EMAIL_OVERRIDE=
SYNC_DATA_DIR=/data/sync

GITHUB_REPO=mevingrivault/aerodirectory
IMAGE_TAG=latest

PROXY_NETWORK=npm_network

ALTCHA_HMAC_KEY=
ALTCHA_ENABLED=true
ALTCHA_MAX_NUMBER=100000
