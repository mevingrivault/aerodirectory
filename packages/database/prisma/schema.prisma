generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "osm"]
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  VISITOR
  MEMBER
  MODERATOR
  ADMIN

  @@schema("public")
}

enum AerodromeStatus {
  OPEN
  CLOSED
  RESTRICTED
  SEASONAL

  @@schema("public")
}

enum AerodromeType {
  SMALL_AIRPORT
  INTERNATIONAL_AIRPORT
  GLIDER_SITE
  ULTRALIGHT_FIELD
  HELIPORT
  MILITARY
  SEAPLANE_BASE
  OTHER

  @@schema("public")
}

enum SurfaceType {
  ASPHALT
  CONCRETE
  GRASS
  GRAVEL
  DIRT
  WATER
  OTHER

  @@schema("public")
}

enum FrequencyType {
  TWR
  AFIS
  ATIS
  APP
  UNICOM
  GROUND
  CTAF
  FIS
  OTHER

  @@schema("public")
}

enum FuelType {
  AVGAS_100LL
  UL91
  JET_A1
  SP98

  @@schema("public")
}

enum PaymentType {
  CARD
  CASH
  TOTAL_CARD
  BP_CARD
  OTHER

  @@schema("public")
}

enum VisitStatus {
  SEEN
  VISITED
  FAVORITE

  @@schema("public")
}

enum ContentStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED

  @@schema("public")
}

enum AuditAction {
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGE
  EMAIL_CHANGE
  TOTP_ENABLE
  TOTP_DISABLE
  ACCOUNT_CREATE
  ACCOUNT_DELETE
  ROLE_CHANGE
  COMMENT_CREATE
  COMMENT_DELETE
  CORRECTION_PROPOSE
  REPORT_CREATE
  ADMIN_ACTION

  @@schema("public")
}

// ─── User ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String
  totpSecret    String?
  totpEnabled   Boolean   @default(false)
  role                Role      @default(MEMBER)
  displayName         String?
  homeAerodromeId     String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  homeAerodrome    Aerodrome?        @relation("UserHomeAerodrome", fields: [homeAerodromeId], references: [id])
  visits           Visit[]
  comments         Comment[]
  corrections      Correction[]
  reports          Report[]
  aircraftProfiles AircraftProfile[]
  auditLogs        AuditLog[]
  emailTokens      EmailToken[]

  @@index([email])
  @@map("users")
  @@schema("public")
}

model EmailToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  type      String // "verify" | "reset"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("email_tokens")
  @@schema("public")
}

// ─── Aerodrome ───────────────────────────────────────────

model Aerodrome {
  id               String          @id @default(cuid())
  name             String
  icaoCode         String?         @unique
  altIdentifier    String?
  latitude         Float
  longitude        Float
  elevation        Int? // feet
  city             String?
  region           String?
  department       String?
  countryCode      String          @default("FR")
  aerodromeType    AerodromeType   @default(SMALL_AIRPORT)
  status           AerodromeStatus @default(OPEN)
  aipLink          String?
  vacLink          String?
  websiteUrl       String?
  description      String?
  hasRestaurant    Boolean         @default(false)
  hasBikes         Boolean         @default(false)
  hasTransport     Boolean         @default(false)
  hasAccommodation Boolean         @default(false)
  hasMaintenance   Boolean         @default(false)
  hasHangars       Boolean         @default(false)
  nightOperations  Boolean         @default(false)

  // ─── Source tracking ──────────────────────────
  source         String? // e.g. "openaip", "sia", "manual"
  sourceId       String? // external unique ID from data source
  sourceRawHash  String? // hash of raw payload for change detection
  lastSyncedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runways     Runway[]
  frequencies Frequency[]
  fuels       Fuel[]
  visits      Visit[]
  comments    Comment[]
  corrections Correction[]
  reports     Report[]
  homeUsers   User[]       @relation("UserHomeAerodrome")

  @@unique([source, sourceId])
  @@index([icaoCode])
  @@index([name])
  @@index([city])
  @@index([region])
  @@index([countryCode])
  @@index([aerodromeType])
  @@map("aerodromes")
  @@schema("public")
}

model Runway {
  id          String      @id @default(cuid())
  aerodromeId String
  identifier  String // e.g. "09/27"
  length      Int // meters
  width       Int? // meters
  surface     SurfaceType
  lighting    Boolean     @default(false)
  remarks     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  aerodrome Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@map("runways")
  @@schema("public")
}

model Frequency {
  id          String        @id @default(cuid())
  aerodromeId String
  type        FrequencyType
  mhz         Float
  callsign    String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  aerodrome Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@map("frequencies")
  @@schema("public")
}

model Fuel {
  id                String      @id @default(cuid())
  aerodromeId       String
  type              FuelType
  available         Boolean     @default(true)
  selfService       Boolean     @default(false)
  availabilityHours String? // e.g. "08:00-18:00"
  paymentType       PaymentType @default(CARD)
  remarks           String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  aerodrome Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@unique([aerodromeId, type])
  @@map("fuels")
  @@schema("public")
}

// ─── Collaborative features ─────────────────────────────

model Visit {
  id          String      @id @default(cuid())
  userId      String
  aerodromeId String
  status      VisitStatus @default(VISITED)
  visitedAt   DateTime    @default(now())
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  aerodrome Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@unique([userId, aerodromeId])
  @@map("visits")
  @@schema("public")
}

model Comment {
  id            String        @id @default(cuid())
  userId        String
  aerodromeId   String
  content       String
  contentStatus ContentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  aerodrome Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@index([aerodromeId])
  @@map("comments")
  @@schema("public")
}

model Correction {
  id            String        @id @default(cuid())
  userId        String
  aerodromeId   String
  field         String
  currentValue  String?
  proposedValue String
  reason        String?
  contentStatus ContentStatus @default(PENDING)
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  aerodrome Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@map("corrections")
  @@schema("public")
}

model Report {
  id            String        @id @default(cuid())
  userId        String
  aerodromeId   String
  targetType    String // "comment" | "correction"
  targetId      String
  reason        String
  contentStatus ContentStatus @default(PENDING)
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  aerodrome Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@map("reports")
  @@schema("public")
}

// ─── Flight Planner ──────────────────────────────────────

model AircraftProfile {
  id               String       @id @default(cuid())
  userId           String
  name             String // e.g. "My C172"
  tas              Float // knots
  fuelConsumption  Float // liters per hour
  hourlyCost       Float // euros per hour
  fuelRange        Float // nautical miles
  minRunwayLength  Int // meters
  allowedSurfaces  SurfaceType[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("aircraft_profiles")
  @@schema("public")
}

// ─── Audit Log ───────────────────────────────────────────

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
  @@schema("public")
}

// ─── Airspace (future use) ──────────────────────────────

model Airspace {
  id         String  @id @default(cuid())
  name       String
  class      String // A, B, C, D, E, G, CTR, TMA, etc.
  lowerLimit String // e.g. "SFC", "FL065", "3500ft AMSL"
  upperLimit String // e.g. "FL195", "6000ft AMSL"
  geometry   Json // GeoJSON polygon
  source     String? // e.g. "openaip", "openair"
  sourceId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, sourceId])
  @@index([class])
  @@map("airspaces")
  @@schema("public")
}

// ─── OSM data (schema: osm) ──────────────────────────────
// Populated by `pnpm import:osm` — never written by the app at runtime.
// Isolated in the `osm` PostgreSQL schema to keep app migrations clean.

model OsmPoi {
  osmId    String @id          // "node/123456" | "way/789"
  lat      Float
  lon      Float
  category String               // "RESTAURANT" | "TRANSPORT" | "BIKE"
  tags     Json                 // raw OSM tags — mirrors OverpassElement.tags

  importedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category, lat, lon])
  @@map("pois")
  @@schema("osm")
}
