generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "osm"]
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  VISITOR
  MEMBER
  MODERATOR
  ADMIN

  @@schema("public")
}

enum UserStatus {
  ACTIVE
  BANNED

  @@schema("public")
}

enum AerodromeStatus {
  OPEN
  CLOSED
  RESTRICTED
  SEASONAL

  @@schema("public")
}

enum AerodromeType {
  SMALL_AIRPORT
  INTERNATIONAL_AIRPORT
  GLIDER_SITE
  ULTRALIGHT_FIELD
  HELIPORT
  ALTIPORT
  MILITARY
  SEAPLANE_BASE
  OTHER

  @@schema("public")
}

enum SurfaceType {
  ASPHALT
  CONCRETE
  GRASS
  GRAVEL
  DIRT
  WATER
  OTHER

  @@schema("public")
}

enum FrequencyType {
  TWR
  AFIS
  ATIS
  APP
  UNICOM
  GROUND
  CTAF
  FIS
  OTHER

  @@schema("public")
}

enum FuelType {
  AVGAS_100LL
  UL91
  JET_A1
  SP98

  @@schema("public")
}

enum PaymentType {
  CARD
  CASH
  TOTAL_CARD
  BP_CARD
  OTHER

  @@schema("public")
}

enum VisitStatus {
  SEEN
  VISITED
  FAVORITE

  @@schema("public")
}

enum ContentStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED

  @@schema("public")
}

enum PhotoStatus {
  PENDING
  SCANNING
  REJECTED
  READY

  @@schema("public")
}

enum SyncSource {
  OPENAIP
  AIRSPACES
  OSM
  REGIONS
  RGPD

  @@schema("public")
}

enum SyncRunType {
  SCHEDULED
  MANUAL
  RETRY
  RECOVERY

  @@schema("public")
}

enum SyncRunStatus {
  QUEUED
  RETRY_SCHEDULED
  IN_PROGRESS
  SUCCESS
  PARTIAL
  FAILED
  SKIPPED

  @@schema("public")
}

enum SyncStepStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED

  @@schema("public")
}

enum AuditAction {
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGE
  EMAIL_CHANGE
  TOTP_ENABLE
  TOTP_DISABLE
  ACCOUNT_CREATE
  ACCOUNT_DELETE
  ROLE_CHANGE
  COMMENT_CREATE
  COMMENT_DELETE
  CORRECTION_PROPOSE
  REPORT_CREATE
  ADMIN_ACTION
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET
  PHOTO_UPLOAD
  PHOTO_APPROVE
  PHOTO_REJECT
  PHOTO_DELETE
  USER_BAN
  USER_UNBAN

  @@schema("public")
}

// ─── User ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String
  totpSecret    String?
  totpEnabled   Boolean   @default(false)
  status        UserStatus @default(ACTIVE)
  bannedAt      DateTime?
  bannedReason  String?
  bannedById    String?
  role                Role      @default(MEMBER)
  displayName         String?   @unique
  homeAerodromeId     String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  homeAerodrome    Aerodrome?        @relation("UserHomeAerodrome", fields: [homeAerodromeId], references: [id])
  visits           Visit[]
  comments         Comment[]          @relation("CommentAuthor")
  deletedComments  Comment[]          @relation("CommentDeletedBy")
  corrections      Correction[]
  reports          Report[]
  aircraftProfiles AircraftProfile[]
  savedSearches    SavedSearch[]
  aerodromeLists   AerodromeList[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  emailTokens      EmailToken[]
  bannedBy         User?             @relation("UserBans", fields: [bannedById], references: [id], onDelete: SetNull)
  bannedUsers      User[]            @relation("UserBans")
  photos           Photo[]
  reviewedPhotos   Photo[]           @relation("PhotoReviewedBy")
  triggeredSyncRuns SyncRun[]        @relation("SyncRunTriggeredBy")

  @@index([email])
  @@index([status])
  @@map("users")
  @@schema("public")
}

model EmailToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  type      String // "verify" | "reset"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("email_tokens")
  @@schema("public")
}

// ─── Aerodrome ───────────────────────────────────────────

model Aerodrome {
  id               String          @id @default(cuid())
  name             String
  icaoCode         String?         @unique
  iataCode         String?
  altIdentifier    String?
  latitude         Float
  longitude        Float
  elevation        Int? // feet
  magneticDeclination Float?
  city             String?
  region           String?
  department       String?
  countryCode      String          @default("FR")
  aerodromeType    AerodromeType   @default(SMALL_AIRPORT)
  status           AerodromeStatus @default(OPEN)
  ppr              Boolean         @default(false)
  privateUse       Boolean         @default(false)
  skydiveActivity  Boolean         @default(false)
  winchOnly        Boolean         @default(false)
  aipLink          String?
  vacLink          String?
  websiteUrl       String?
  description      String?
  handlingFacilities  Int[]        @default([])
  passengerFacilities Int[]        @default([])
  hasRestaurant    Boolean         @default(false)
  hasBikes         Boolean         @default(false)
  hasTransport     Boolean         @default(false)
  hasAccommodation Boolean         @default(false)
  hasMaintenance   Boolean         @default(false)
  hasHangars       Boolean         @default(false)
  nightOperations  Boolean         @default(false)

  // ─── Source tracking ──────────────────────────
  source         String? // e.g. "openaip", "sia", "manual"
  sourceId       String? // external unique ID from data source
  sourceRawHash  String? // hash of raw payload for change detection
  lastSyncedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runways     Runway[]
  frequencies Frequency[]
  fuels       Fuel[]
  visits      Visit[]
  comments    Comment[]
  corrections Correction[]
  reports     Report[]
  listItems   AerodromeListItem[]
  homeUsers   User[]       @relation("UserHomeAerodrome")
  photos      Photo[]

  @@unique([source, sourceId])
  @@index([icaoCode])
  @@index([name])
  @@index([city])
  @@index([region])
  @@index([countryCode])
  @@index([aerodromeType])
  @@map("aerodromes")
  @@schema("public")
}

model Runway {
  id          String      @id @default(cuid())
  aerodromeId String
  identifier  String // e.g. "09/27"
  length      Int // meters
  width       Int? // meters
  trueHeading Int?
  mainRunway  Boolean     @default(false)
  operations  Int?
  surface     SurfaceType
  surfaceComposition Int[] @default([])
  lighting    Boolean     @default(false)
  remarks     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  aerodrome Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@map("runways")
  @@schema("public")
}

model Frequency {
  id          String        @id @default(cuid())
  aerodromeId String
  type        FrequencyType
  mhz         Float
  isPrimary   Boolean       @default(false)
  callsign    String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  aerodrome Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@map("frequencies")
  @@schema("public")
}

model Fuel {
  id                String      @id @default(cuid())
  aerodromeId       String
  type              FuelType
  available         Boolean     @default(true)
  selfService       Boolean     @default(false)
  availabilityHours String? // e.g. "08:00-18:00"
  paymentType       PaymentType @default(CARD)
  remarks           String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  aerodrome Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@unique([aerodromeId, type])
  @@map("fuels")
  @@schema("public")
}

// ─── Collaborative features ─────────────────────────────

model Visit {
  id          String      @id @default(cuid())
  userId      String
  aerodromeId String
  status      VisitStatus @default(VISITED)
  visitedAt   DateTime    @default(now())
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  aerodrome Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@unique([userId, aerodromeId])
  @@map("visits")
  @@schema("public")
}

model Comment {
  id            String        @id @default(cuid())
  userId        String
  aerodromeId   String
  parentId      String?
  content       String
  contentStatus ContentStatus @default(PENDING)
  deletedAt     DateTime?
  deletedReason String?
  deletedById   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user      User      @relation("CommentAuthor", fields: [userId], references: [id], onDelete: Cascade)
  deletedBy User?     @relation("CommentDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  aerodrome Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@index([aerodromeId])
  @@index([parentId])
  @@index([deletedAt])
  @@map("comments")
  @@schema("public")
}

model Correction {
  id            String        @id @default(cuid())
  userId        String
  aerodromeId   String
  field         String
  currentValue  String?
  proposedValue String
  reason        String?
  contentStatus ContentStatus @default(PENDING)
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  aerodrome Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@map("corrections")
  @@schema("public")
}

model Report {
  id            String        @id @default(cuid())
  userId        String
  aerodromeId   String
  targetType    String // "comment" | "correction"
  targetId      String
  reason        String
  contentStatus ContentStatus @default(PENDING)
  reviewedBy    String?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  aerodrome Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@map("reports")
  @@schema("public")
}

// ─── Flight Planner ──────────────────────────────────────

model AircraftProfile {
  id               String       @id @default(cuid())
  userId           String
  name             String // e.g. "My C172"
  tas              Float // knots
  fuelConsumption  Float // liters per hour
  hourlyCost       Float // euros per hour
  fuelRange        Float // nautical miles
  minRunwayLength  Int // meters
  allowedSurfaces  SurfaceType[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("aircraft_profiles")
  @@schema("public")
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String
  scope     String   @default("search") // "search" | "planner"
  params    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scope])
  @@map("saved_searches")
  @@schema("public")
}

model AerodromeList {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items AerodromeListItem[]

  @@unique([userId, name])
  @@index([userId, createdAt])
  @@map("aerodrome_lists")
  @@schema("public")
}

model AerodromeListItem {
  id          String   @id @default(cuid())
  listId      String
  aerodromeId String
  note        String?
  createdAt   DateTime @default(now())

  list      AerodromeList @relation(fields: [listId], references: [id], onDelete: Cascade)
  aerodrome Aerodrome     @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@unique([listId, aerodromeId])
  @@index([aerodromeId])
  @@map("aerodrome_list_items")
  @@schema("public")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  linkUrl   String?
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
  @@schema("public")
}

// ─── Audit Log ───────────────────────────────────────────

model AuditLog {
  id        String      @id @default(cuid())
  userId    String?
  action    AuditAction
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
  @@schema("public")
}

model SyncRun {
  id                String        @id @default(cuid())
  source            SyncSource
  runType           SyncRunType
  scope             String?
  status            SyncRunStatus @default(QUEUED)
  attempt           Int           @default(1)
  scheduledFor      DateTime
  startedAt         DateTime?
  finishedAt        DateTime?
  durationMs        Int?
  summary           Json?
  errorMessage      String?
  recipients        String[]
  nextRetryAt       DateTime?
  triggeredByUserId String?
  workerId          String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  triggeredBy User?         @relation("SyncRunTriggeredBy", fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  steps       SyncRunStep[]

  @@index([source, status])
  @@index([status, scheduledFor])
  @@index([nextRetryAt])
  @@index([createdAt])
  @@map("sync_runs")
  @@schema("public")
}

model SyncRunStep {
  id           String         @id @default(cuid())
  runId        String
  stepKey      String
  stepOrder    Int
  status       SyncStepStatus @default(PENDING)
  startedAt    DateTime?
  finishedAt   DateTime?
  durationMs   Int?
  metrics      Json?
  checkpoint   Json?
  artifactPath String?
  logSummary   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  run SyncRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, stepKey])
  @@index([status])
  @@index([runId, stepOrder])
  @@map("sync_run_steps")
  @@schema("public")
}


// ─── Photo ───────────────────────────────────────────────

model Photo {
  id               String      @id @default(cuid())
  userId           String
  aerodromeId      String
  originalFilename String?
  storedFilename   String      // UUID-based, never the original name
  storedKey        String      // S3 object key
  mimeType         String      // final MIME type after conversion
  size             Int         // bytes after processing
  width            Int?
  height           Int?
  status           PhotoStatus @default(PENDING)
  rejectedReason   String?
  reviewedById     String?
  reviewedAt       DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?     @relation("PhotoReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  aerodrome  Aerodrome @relation(fields: [aerodromeId], references: [id], onDelete: Cascade)

  @@index([aerodromeId, status])
  @@index([status, createdAt])
  @@index([userId])
  @@index([reviewedById])
  @@map("photos")
  @@schema("public")
}

// ─── Airspace ────────────────────────────────────────────

model Airspace {
  id          String  @id @default(cuid())
  name        String
  // openAIP type code (0=Other, 1=Restricted, 2=Danger, 3=Prohibited, 4=CTR, 5=TMA,
  //   6=RMZ, 7=TMZ, 8=FIR, 9=UIR, 10=ADIZ, 11=ATZ, 12=MATZ, 13=Airway,
  //   14=MTR, 15=Alert, 16=Warning, 17=Protected, 18=HTZ, 19=Glider, 20=TRP,
  //   21=TIZ, 22=TIA, 23=MBZ, 24=GP, 25=WTSZ, 26=NOTAM)
  type        Int
  // ICAO class: A B C D E F G or special codes
  icaoClass   String
  // Altitude limits — stored as human-readable strings (e.g. "SFC", "FL065", "3500ft MSL")
  lowerLimit  String
  upperLimit  String
  // Raw limit values for filtering
  lowerLimitFt  Int?   // feet MSL, null = SFC (0) or unknown
  upperLimitFt  Int?   // feet MSL, null = unlimited or unknown
  // GeoJSON polygon geometry (type: "Polygon" | "MultiPolygon", coordinates: ...)
  geometry    Json
  countryCode String  @default("FR")
  // openAIP specific
  activity    Int?    // 0=All, 1=Parachute, 2=Aerobatic, 3=Airshow, 4=Glider...
  onDemand    Boolean @default(false)
  onRequest   Boolean @default(false)
  remarks     String?

  sourceId    String?
  sourceRawHash String?
  lastSyncedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceId])
  @@index([type])
  @@index([icaoClass])
  @@index([countryCode])
  @@map("airspaces")
  @@schema("public")
}

// ─── OSM data (schema: osm) ──────────────────────────────
// Populated by `pnpm import:osm` — never written by the app at runtime.
// Isolated in the `osm` PostgreSQL schema to keep app migrations clean.

model OsmPoi {
  osmId    String @id          // "node/123456" | "way/789"
  lat      Float
  lon      Float
  category String               // "RESTAURANT" | "TRANSPORT" | "BIKE"
  tags     Json                 // raw OSM tags — mirrors OverpassElement.tags

  importedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([category, lat, lon])
  @@map("pois")
  @@schema("osm")
}
