# Local app + remote database configuration.
# Copy this file to .env.remote.local and fill in the real remote credentials.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/aerodirectory?schema=public&sslmode=require"

# Optional: point to production Redis if you want to test shared caching.
# Leave empty to use in-memory cache locally.
REDIS_URL=""

JWT_SECRET="dev-only-jwt-secret-change-in-production!!"
JWT_REFRESH_SECRET="dev-only-refresh-secret-change-in-production!!"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"

# Optional local email capture.
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_FROM="noreply@navventura.fr"

# Optional S3 config if you want to test uploads locally.
S3_ENDPOINT=""
S3_BUCKET="aerodirectory"
S3_REGION="auto"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_PUBLIC_URL=""

OPENAIP_API_KEY="your_openaip_api_key_here"
CHECKWX_API_KEY="your_checkwx_api_key_here"

ALTCHA_HMAC_KEY="change-me-generate-with-openssl-rand-hex-32"
ALTCHA_ENABLED="false"
CLAMSCAN_ENABLED="false"
ALTCHA_MAX_NUMBER=100000
