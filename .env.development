# Default development environment — safe to commit (no real secrets)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/aerodirectory?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="dev-only-jwt-secret-change-in-production!!"
JWT_REFRESH_SECRET="dev-only-refresh-secret-change-in-production!!"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_FROM="noreply@navventura.fr"
S3_ENDPOINT="http://localhost:8333"
S3_BUCKET="aerodirectory"

# openAIP — aviation data source (https://www.openaip.net/)
# Get your free API key at https://www.openaip.net/users/signup
# This placeholder won't work — replace with your real key in .env
OPENAIP_API_KEY="your_openaip_api_key_here"

# CheckWX — METAR/TAF weather data (https://www.checkwxapi.com/)
# Get your free API key at https://www.checkwxapi.com/
CHECKWX_API_KEY="your_checkwx_api_key_here"
