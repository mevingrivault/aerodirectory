{
  "name": "aerodirectory",
  "private": true,
  "version": "0.1.0",
  "description": "Collaborative Directory of French Aerodromes",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "bootstrap": "node scripts/setup.mjs",
    "setup": "node scripts/setup.mjs",
    "setup:remote": "node scripts/setup.mjs --remote",
    "dev": "pnpm db:generate && pnpm --filter @aerodirectory/shared build && pnpm --parallel -r dev",
    "infra:up": "docker compose up -d postgres redis seaweedfs-master seaweedfs-volume seaweedfs-filer mailpit",
    "infra:down": "docker compose down",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "admin:promote": "tsx scripts/promote-admin.ts",
    "db:generate": "pnpm --filter @aerodirectory/database prisma:generate",
    "db:migrate": "pnpm --filter @aerodirectory/database prisma:migrate",
    "db:seed": "pnpm --filter @aerodirectory/database prisma:seed",
    "import:openaip": "pnpm db:generate && tsx scripts/import-openaip.ts",
    "import:openair": "pnpm db:generate && tsx scripts/import-openair.ts",
    "import:osm": "pnpm db:generate && tsx scripts/import-osm.ts && tsx scripts/sync-aerodrome-flags.ts",
    "sync:flags": "pnpm db:generate && tsx scripts/sync-aerodrome-flags.ts",
    "sync:regions": "pnpm db:generate && tsx scripts/sync-aerodrome-regions.ts"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "overrides": {
      "lodash": ">=4.18.0",
      "defu": ">=6.1.5",
      "picomatch": ">=4.0.4",
      "effect": ">=3.20.0",
      "brace-expansion": ">=1.1.13",
      "ajv": ">=8.18.0",
      "fastify": "5.8.5",
      "@types/jsonwebtoken": "9.0.9"
    },
    "patchedDependencies": {
      "altcha-lib@2.0.2": "patches/altcha-lib@2.0.2.patch"
    }
  }
}
